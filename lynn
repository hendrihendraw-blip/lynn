local function tw(obj, props, t, style)
	return TweenService:Create(obj,
		TweenInfo.new(t or 0.18, style or Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
end
local function corner(p, r)
	local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 8); c.Parent=p
end
local function stroke(p, col, thick)
	local s=Instance.new("UIStroke"); s.Color=col or C.borderMid
	s.Thickness=thick or 1; s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
	s.Parent=p; return s
end
local function lbl(parent, text, font, size, color, xAlign)
	local l=Instance.new("TextLabel"); l.BackgroundTransparency=1
	l.Text=text; l.Font=font or Enum.Font.Gotham
	l.TextSize=size or 11; l.TextColor3=color or C.textPri
	l.TextXAlignment=xAlign or Enum.TextXAlignment.Left
	l.TextScaled=false; l.Parent=parent; return l
end
local function frame(parent, size, pos, bg_, radius)
	local f=Instance.new("Frame"); f.Size=size
	f.Position=pos or UDim2.new(0,0,0,0)
	f.BackgroundColor3=bg_ or C.surface
	f.BorderSizePixel=0; f.Parent=parent
	if radius then corner(f,radius) end; return f
end
local function addPressEffect(btn, pressColor, normalColor)
	btn.MouseButton1Down:Connect(function()
		tw(btn,{BackgroundColor3=pressColor},0.08):Play()
	end)
	btn.MouseButton1Up:Connect(function()
		tw(btn,{BackgroundColor3=normalColor},0.15):Play()
	end)
end

