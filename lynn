local function makeSlider(parent,layoutOrder,iconText,iconBg,iconColor,title,defaultVal,minVal,maxVal,labelMin,labelMax,onChange)
	local sCard=frame(parent,UDim2.new(1,0,0,48),UDim2.new(0,0,0,0),C.surface,8)
	sCard.LayoutOrder=layoutOrder; stroke(sCard,C.borderMid)
	local ib=frame(sCard,UDim2.new(0,22,0,22),UDim2.new(0,5,0.5,-11),iconBg,6)
	local sIbL=lbl(ib,iconText,Enum.Font.GothamBold,7,iconColor,Enum.TextXAlignment.Center)
	sIbL.Size=UDim2.new(1,0,1,0)
	local sTitle=lbl(sCard,title,Enum.Font.GothamBold,9,C.textPri)
	sTitle.Size=UDim2.new(0,80,0,18); sTitle.Position=UDim2.new(0,32,0,4)
	local curVal=defaultVal
	local sNum=lbl(sCard,tostring(defaultVal),Enum.Font.GothamBold,11,iconColor,Enum.TextXAlignment.Right)
	sNum.Size=UDim2.new(0,40,0,18); sNum.Position=UDim2.new(1,-44,0,4)
	local trackBg=frame(sCard,UDim2.new(1,-20,0,5),UDim2.new(0,10,0,30),Color3.fromRGB(16,26,42),3)
	local trackFill=frame(trackBg,UDim2.new(0.01,0,1,0),UDim2.new(0,0,0,0),iconColor,3)
	local thumbSz=12
	local thumb=Instance.new("TextButton")
	thumb.Size=UDim2.new(0,thumbSz,0,thumbSz); thumb.BackgroundColor3=iconColor
	thumb.Text=""; thumb.AutoButtonColor=false; thumb.BorderSizePixel=0; thumb.Parent=sCard
	corner(thumb,99)
	local function toPct(v) return (v-minVal)/(maxVal-minVal) end
	local function fromPct(p) return math.floor(minVal+p*(maxVal-minVal)) end
	local function applyVal(v)
		curVal=math.clamp(v,minVal,maxVal)
		sNum.Text=tostring(curVal)
		local pct=toPct(curVal)
		tw(trackFill,{Size=UDim2.new(math.clamp(pct,0.01,1),0,1,0)},0.08):Play()
		local tW=sCard.AbsoluteSize.X-20; local tX=10+pct*tW-thumbSz/2
		thumb.Position=UDim2.new(0,tX,0,30-(thumbSz-5)/2)
		onChange(curVal)
	end
	local dragging=false; local bound=false
	local function getPct(inputPos)
		local abs=trackBg.AbsolutePosition; local w=trackBg.AbsoluteSize.X
		return math.clamp((inputPos.X-abs.X)/w,0,1)
	end
	local function onInput(inp)
		if inp.UserInputType==Enum.UserInputType.Touch
		or inp.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=true; applyVal(fromPct(getPct(inp.Position)))
			if not bound then bound=true
				ContextActionService:BindAction("SliderBlock"..title,function()
					return Enum.ContextActionResult.Sink
				end,false,Enum.UserInputType.Touch,Enum.UserInputType.MouseMovement,
				Enum.KeyCode.Thumbstick1,Enum.KeyCode.Thumbstick2)
			end
		end
	end
	UIS.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType==Enum.UserInputType.Touch
		or inp.UserInputType==Enum.UserInputType.MouseMovement then
			applyVal(fromPct(getPct(inp.Position)))
		end
	end)
	UIS.InputEnded:Connect(function(inp)
		if dragging and (inp.UserInputType==Enum.UserInputType.Touch
		or inp.UserInputType==Enum.UserInputType.MouseButton1) then
			dragging=false
			if bound then bound=false; ContextActionService:UnbindAction("SliderBlock"..title) end
		end
	end)
	trackBg.InputBegan:Connect(onInput)
	trackFill.InputBegan:Connect(onInput)
	thumb.InputBegan:Connect(onInput)
	task.defer(function() applyVal(curVal) end)
	return sCard,function() return curVal end
end

