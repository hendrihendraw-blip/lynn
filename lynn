		tw(floatList,{Size=UDim2.new(0,PANEL_W-12,0,realListH)},0.18,Enum.EasingStyle.Back):Play()
		arrB.Text="^"; arrB.TextColor3=C.accent; tw(cStroke,{Color=Color3.fromRGB(30,90,75)},0.12):Play()
		isOpen=true
	end
	card.MouseButton1Click:Connect(function()
		if isOpen then closeThis(); if activeDropdown==closeThis then activeDropdown=nil end
		else closeActiveDropdown(); openThis(); activeDropdown=closeThis end
	end)
	return card
end

