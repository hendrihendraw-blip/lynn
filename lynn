		end
		local d=espData[p]; if not d then continue end
		local char=p.Character
		local hrp=char and char:FindFirstChild("HumanoidRootPart")
		local myHRP=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if d.highlight then d.highlight.Enabled=espEnabled.highlight end
		local bbOn=espEnabled.name or espEnabled.distance
		if d.billboard then d.billboard.Enabled=bbOn end
		if d.nameL then d.nameL.Visible=espEnabled.name; d.nameL.Text=p.DisplayName end
		if d.distL and hrp and myHRP then
			d.distL.Visible=espEnabled.distance
			d.distL.Text=math.floor((hrp.Position-myHRP.Position).Magnitude).." studs"
		end
	end
end)

