local isFlying=false; local flyThread=nil
local flyBg=nil; local flyBv=nil; local flyAnimTrack=nil

local function startFly()
    isFlying=true
    local char=player.Character; if not char then isFlying=false; return end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then isFlying=false; return end
    hum.PlatformStand=true
    for _,v in ipairs(hrp:GetChildren()) do
        if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end
    end
    flyBg=Instance.new("BodyGyro")
    flyBg.P=9e4; flyBg.MaxTorque=Vector3.new(9e9,9e9,9e9)
    flyBg.CFrame=hrp.CFrame; flyBg.Parent=hrp
    flyBv=Instance.new("BodyVelocity")
    flyBv.Velocity=Vector3.zero; flyBv.MaxForce=Vector3.new(9e9,9e9,9e9); flyBv.Parent=hrp
    pcall(function()
        local anim=Instance.new("Animation"); anim.AnimationId="rbxassetid://616010382"
        flyAnimTrack=hum:LoadAnimation(anim); flyAnimTrack:Play(); flyAnimTrack:AdjustSpeed(0)
    end)
    local currentVel=Vector3.zero
    local ACCEL=0.12; local DECEL=0.08
    flyThread=RunService.RenderStepped:Connect(function(dt)
        if not isFlying then return end
        if not hrp or not hrp.Parent then return end
        if not flyBv or not flyBv.Parent then return end
        if not flyBg or not flyBg.Parent then return end
        local cam=workspace.CurrentCamera
        local moveDir=hum.MoveDirection
        local targetVel=Vector3.zero
        if moveDir.Magnitude>0 then
            local camCF=cam.CFrame
            local camLookFlat=Vector3.new(camCF.LookVector.X,0,camCF.LookVector.Z).Unit
            local camRightFlat=Vector3.new(camCF.RightVector.X,0,camCF.RightVector.Z).Unit
            local fwd=moveDir:Dot(camLookFlat)
            local right=moveDir:Dot(camRightFlat)
            targetVel=(camCF.LookVector*fwd + camCF.RightVector*right)*FLY_SPEED
        end
        local lerpFactor=moveDir.Magnitude>0 and ACCEL or DECEL
        currentVel=currentVel:Lerp(targetVel,math.min(lerpFactor*60*dt,1))
        flyBv.Velocity=currentVel
        local camCF2=cam.CFrame; local tiltAngle=0
        if moveDir.Magnitude>0 then
            local fwd2=moveDir:Dot(Vector3.new(camCF2.LookVector.X,0,camCF2.LookVector.Z).Unit)
            tiltAngle=fwd2*25
        end
        flyBg.CFrame=camCF2*CFrame.Angles(-math.rad(tiltAngle),0,0)
        if flyAnimTrack then
            local animSpeed=currentVel.Magnitude/FLY_SPEED
            pcall(function() flyAnimTrack:AdjustSpeed(animSpeed*1.5) end)
        end
    end)
    setTog(flyBtn,flyBadge,flyStroke,flyIb,flyIbL,true,C.blue,C.blueDim)
    flySliderCard.Visible=true
end

local function stopFly()
    isFlying=false
    if flyThread then flyThread:Disconnect(); flyThread=nil end
    local char=player.Character
    if char then
        local hrp=char:FindFirstChild("HumanoidRootPart")
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hrp then
            for _,v in ipairs(hrp:GetChildren()) do
                if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end
            end
        end
        if hum then
            hum.PlatformStand=false
            for _,track in ipairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
        end
    end
    flyBg=nil; flyBv=nil; flyAnimTrack=nil
    setTog(flyBtn,flyBadge,flyStroke,flyIb,flyIbL,false,C.blue,C.blueDim)
    flySliderCard.Visible=false
end

flyBtn.MouseButton1Click:Connect(function()
    if isFlying then stopFly() else startFly() end
end)

player.CharacterAdded:Connect(function()
    if isFlying then
        isFlying=false
        if flyThread then flyThread:Disconnect(); flyThread=nil end
        flyBg=nil; flyBv=nil; flyAnimTrack=nil
        flySliderCard.Visible=false
        setTog(flyBtn,flyBadge,flyStroke,flyIb,flyIbL,false,C.blue,C.blueDim)
        task.delay(1, startFly)
    end
end)

