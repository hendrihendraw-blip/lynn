local function getAllStorageIds()
	local ids={}; if not myPlot then return ids end
	local objects=myPlot:FindFirstChild("Objects"); if not objects then return ids end
	for _,v in ipairs(objects:GetChildren()) do
		if v.Name=="Storage" then local oid=v:GetAttribute("ObjectId"); if oid then table.insert(ids,oid) end end
	end
	return ids
end
local function getFactoryId()
	if not myPlot then return nil end
	local objects=myPlot:FindFirstChild("Objects"); if not objects then return nil end
	for _,v in ipairs(objects:GetChildren()) do
		if v:GetAttribute("DefinitionId")=="factory1" then return v:GetAttribute("ObjectId") end
	end
end
local function isOccupied(lx,lz)
	if not myPlot then return false end
	local objects=myPlot:FindFirstChild("Objects"); if not objects then return false end
	for _,v in ipairs(objects:GetChildren()) do
		local ox=v:GetAttribute("LocalX"); local oz=v:GetAttribute("LocalZ")
		if ox and oz and math.abs(ox-lx)<1 and math.abs(oz-lz)<1 then return true end
	end
	return false
end
local function getMyRockets()
	local rockets={}; if not myPlot then return rockets end
	local objects=myPlot:FindFirstChild("Objects"); if not objects then return rockets end
	for _,v in ipairs(objects:GetChildren()) do
		if v:GetAttribute("Kind")=="Rocket" then
			local oid=v:GetAttribute("ObjectId"); if oid then table.insert(rockets,{objectId=oid}) end
		end
	end
	return rockets
end
local function getEnemyBuildings(targetUserId)
	local buildings={}; if not world then return buildings end
	for _,plot in ipairs(world:GetChildren()) do
		if plot:GetAttribute("OwnerUserId")==targetUserId then
			local eAnchor=plot:FindFirstChild("Anchor"); local objects=plot:FindFirstChild("Objects")
			if not eAnchor or not objects then break end
			for _,obj in ipairs(objects:GetChildren()) do
				if obj:GetAttribute("Kind")=="Building" then
					local lx=obj:GetAttribute("LocalX"); local lz=obj:GetAttribute("LocalZ")
					if lx and lz then
						local wp=eAnchor.CFrame:PointToWorldSpace(Vector3.new(lx,0,lz))
						table.insert(buildings,{x=wp.X,z=wp.Z,name=obj.Name})
					end
				end
			end
			break
		end
	end
	return buildings
end
local function isRocketSlot(slot)
	local fr=slot:FindFirstChild("Frame")
	local vpf=fr and fr:FindFirstChildOfClass("ViewportFrame")
	local wm=vpf and vpf:FindFirstChildOfClass("WorldModel"); if not wm then return false end
	for _,c in ipairs(wm:GetChildren()) do
		if c:IsA("Model") and c.Name:lower():find("rocket") and not c.Name:lower():find("launcher") then return true end
	end
	return false
end
local function getRocketSlots()
	local slots={}
	local invGui=player.PlayerGui:FindFirstChild("RocketInventoryGui"); if not invGui then return slots end
	local function scan(container)
		if not container then return end
		for _,slot in ipairs(container:GetChildren()) do
			if not slot:IsA("TextButton") then continue end
			local sc=slot:FindFirstChild("StackCount"); local n=sc and tonumber(sc.Text) or 0
			if n>0 and isRocketSlot(slot) then table.insert(slots,{id=slot.Name,count=n}) end
		end
	end
	scan(invGui:FindFirstChild("BottomBar"))
	local ov=invGui:FindFirstChild("OverflowInventoryWindow")
	if ov then scan(ov:FindFirstChild("OverflowInventoryScroll")) end
	return slots
end
local function localToWorld(lx,lz)
	if not anchor then return 0,0 end
	local wp=anchor.CFrame:PointToWorldSpace(Vector3.new(lx,0,lz)); return wp.X,wp.Z
end
local function getCornerInFront()
	local char=player.Character; if not char then return 0,0 end
	local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return 0,0 end
	if not anchor then return 0,0 end
	local look=Vector3.new(hrp.CFrame.LookVector.X,0,hrp.CFrame.LookVector.Z).Unit
	local dist=math.max(COLS,ROWS)*STEP*0.6+2
	local cw=hrp.Position+look*dist
	local lp=anchor.CFrame:PointToObjectSpace(cw)
	local cx=math.round(lp.X/STEP)*STEP; local cz=math.round(lp.Z/STEP)*STEP
	return cx-COLS*STEP/2, cz-ROWS*STEP/2
end
local function generateGrid(cLX,cLZ)
	local slots={}
	for r=0,ROWS-1 do for c=0,COLS-1 do
		table.insert(slots,{localX=cLX+c*STEP,localZ=cLZ+r*STEP})
	end end
	return slots
end

-- BOX VISUAL
local boxParts={}
local function clearBox()
	for _,p in ipairs(boxParts) do pcall(function() p:Destroy() end) end; boxParts={}
end
local function makePart(color)
	local p=Instance.new("Part")
	p.Anchored=true; p.CanCollide=false; p.CastShadow=false
	p.Material=Enum.Material.Neon; p.Color=color
	p.Transparency=0.1; p.Parent=workspace
	table.insert(boxParts,p); return p
end
local function drawBox(cLX,cLZ,color)
	clearBox()
	if not boxVisible then return end
	if not anchor then return end
	color=color or BOX_COLOR
	local char=player.Character; if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
	local BOX_W=math.max(2,COLS-1)*STEP; local BOX_D=math.max(2,ROWS-1)*STEP
	local y=hrp.Position.Y-0.9
	local wx1,wz1=localToWorld(cLX,cLZ)
	local wx2,wz2=localToWorld(cLX+BOX_W,cLZ)
	local wx3,wz3=localToWorld(cLX+BOX_W,cLZ+BOX_D)
	local wx4,wz4=localToWorld(cLX,cLZ+BOX_D)
	local c1=Vector3.new(wx1,y,wz1); local c2=Vector3.new(wx2,y,wz2)
	local c3=Vector3.new(wx3,y,wz3); local c4=Vector3.new(wx4,y,wz4)
	local edges={{c1,c2},{c2,c3},{c3,c4},{c4,c1}}
	for _,e in ipairs(edges) do
		local a,b=e[1],e[2]; local mid=(a+b)/2; local len=(b-a).Magnitude
		if len<0.05 then continue end
		local p=makePart(color); p.Size=Vector3.new(len,0.3,0.3)
		p.CFrame=CFrame.new(mid,mid+(b-a).Unit)*CFrame.Angles(0,math.pi/2,0)
	end
	local floorMid=(c1+c3)/2
	local floor=makePart(color); floor.Size=Vector3.new(BOX_W,0.05,BOX_D); floor.Transparency=0.78
	local _,ry,_=anchor.CFrame:ToEulerAnglesYXZ()
	floor.CFrame=CFrame.new(floorMid)*CFrame.Angles(0,ry,0)
end
RunService.RenderStepped:Connect(function()
	if not anchor then clearBox(); return end
	if not boxVisible then clearBox(); return end
	if boxFrozen then return end
	local cx,cz=getCornerInFront(); drawBox(cx,cz,BOX_COLOR)
end)
local function freezeBox(cx,cz)
	frozenCX,frozenCZ=cx,cz; boxFrozen=true; drawBox(cx,cz,Color3.fromRGB(255,220,0))
end
local function unfreezeBox() boxFrozen=false end

