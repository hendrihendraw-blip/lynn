	arrB.BorderSizePixel=0; arrB.Parent=card; corner(arrB,5); stroke(arrB,C.borderMid)
	local function refreshCnt()
		local n=0; for _,v in pairs(checkedTable) do if v then n+=1 end end; cntB.Text=tostring(n)
	end
	refreshCnt()
	local MAX_VH=200; local ITEM_ROW_H=ITEM_H+2
	local floatList=Instance.new("Frame")
	floatList.Size=UDim2.new(0,PANEL_W-12,0,0)
	floatList.BackgroundColor3=Color3.fromRGB(10,16,26)
	floatList.BorderSizePixel=0; floatList.ClipsDescendants=true
	floatList.Visible=false; floatList.ZIndex=60; floatList.Parent=overlayFrame
	corner(floatList,8); stroke(floatList,C.borderMid)
	local floatScroll=Instance.new("ScrollingFrame")
	floatScroll.Size=UDim2.new(1,0,1,0); floatScroll.BackgroundTransparency=1
	floatScroll.BorderSizePixel=0; floatScroll.ScrollBarThickness=2
	floatScroll.ScrollBarImageColor3=C.borderMid; floatScroll.ZIndex=61; floatScroll.Parent=floatList
	local sectionOrder={"military","building"}
	local sectionLabels={military="-- Military --",building="-- Building --"}
	local sectionColors={military=C.red,building=C.accent}
	local yOff=2
	for _,sec in ipairs(sectionOrder) do
		local secItems={}
		for _,item in ipairs(itemList) do
			if item[5]==sec then table.insert(secItems,item) end
		end
		if #secItems==0 then continue end
		local secLb=Instance.new("TextLabel")
		secLb.Size=UDim2.new(1,-6,0,16); secLb.Position=UDim2.new(0,3,0,yOff)
		secLb.BackgroundTransparency=1; secLb.Text=sectionLabels[sec]
		secLb.Font=Enum.Font.GothamBold; secLb.TextSize=8
		secLb.TextColor3=sectionColors[sec]; secLb.TextXAlignment=Enum.TextXAlignment.Center
		secLb.ZIndex=62; secLb.Parent=floatScroll; yOff+=18
		for _,item in ipairs(secItems) do
			local iName=item[1]; local iTier=item[6]
			local tc=TIER_COLORS[iTier] or TIER_COLORS[1]
			local row=Instance.new("Frame")
			row.Size=UDim2.new(1,-6,0,ITEM_H); row.Position=UDim2.new(0,3,0,yOff)
			row.BackgroundColor3=Color3.fromRGB(14,22,36)
			row.BorderSizePixel=0; row.ZIndex=62; row.Parent=floatScroll; corner(row,5)
			local tierB=Instance.new("TextLabel")
			tierB.Size=UDim2.new(0,20,0,14); tierB.Position=UDim2.new(0,5,0.5,-7)
			tierB.BackgroundColor3=tc.dim; tierB.BorderSizePixel=0
			tierB.Text="T"..iTier; tierB.Font=Enum.Font.GothamBold; tierB.TextSize=7
			tierB.TextColor3=tc.col; tierB.ZIndex=63; tierB.Parent=row; corner(tierB,4)
			local chk=Instance.new("TextButton")
			chk.Size=UDim2.new(0,13,0,13); chk.Position=UDim2.new(0,30,0.5,-6)
			chk.BackgroundColor3=checkedTable[iName] and C.accent or Color3.fromRGB(20,32,50)
			chk.Text=checkedTable[iName] and "v" or ""
			chk.Font=Enum.Font.GothamBold; chk.TextSize=7
			chk.TextColor3=Color3.fromRGB(5,20,16); chk.AutoButtonColor=false
			chk.BorderSizePixel=0; chk.ZIndex=63; chk.Parent=row; corner(chk,3)
			local nl=lbl(row,iName,Enum.Font.Gotham,9,C.textMid)
			nl.Size=UDim2.new(1,-50,1,0); nl.Position=UDim2.new(0,47,0,0); nl.ZIndex=63
			local function tog()
				checkedTable[iName]=not checkedTable[iName]
				chk.BackgroundColor3=checkedTable[iName] and C.accent or Color3.fromRGB(20,32,50)
				chk.Text=checkedTable[iName] and "v" or ""
				tw(row,{BackgroundColor3=checkedTable[iName] and Color3.fromRGB(10,28,24) or Color3.fromRGB(14,22,36)},0.1):Play()
				refreshCnt()
			end
			chk.MouseButton1Click:Connect(tog)
			row.InputBegan:Connect(function(inp)
				if inp.UserInputType==Enum.UserInputType.Touch then
					local sp=inp.Position; local mv=false; local mc
					mc=inp.Changed:Connect(function()
						if inp.UserInputState==Enum.UserInputState.Change then
							if (inp.Position-sp).Magnitude>10 then mv=true end
						end
						if inp.UserInputState==Enum.UserInputState.End then
							mc:Disconnect(); if not mv then tog() end
						end
					end)
				elseif inp.UserInputType==Enum.UserInputType.MouseButton1 then tog() end
			end)
			yOff+=ITEM_ROW_H
		end
	end
	floatScroll.CanvasSize=UDim2.new(0,0,0,yOff+4)
	local realListH=math.min(yOff+4,MAX_VH)
	local isOpen=false
	local function closeThis()
		isOpen=false
		tw(floatList,{Size=UDim2.new(0,PANEL_W-12,0,0)},0.12):Play()
		arrB.Text="v"; arrB.TextColor3=C.textSec; tw(cStroke,{Color=C.borderMid},0.12):Play()
