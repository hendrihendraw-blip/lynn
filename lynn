local function alIsEntitySafe(obj)
	local model = obj:FindFirstAncestorOfClass("Model")
	if model and model:FindFirstChildOfClass("Humanoid") then return true end
	if obj:IsA("Humanoid") then return true end
	return false
end

local alOptActive = false
local function alProcessObject(obj)
	if alIsEntitySafe(obj) then return end
	if obj:IsA("BasePart") then
		if obj.Name:lower():find("baseplate") then return end
		if obj.Size.X > 500 and obj.Size.Z > 500 then return end
	end
	if obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Fire")
	or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Sparkles") then
		if obj:GetAttribute("AL_OrigEnabled") == nil then
			obj:SetAttribute("AL_OrigEnabled", obj.Enabled)
		end
		if alOptActive then obj.Enabled = false
		else pcall(function() obj.Enabled = obj:GetAttribute("AL_OrigEnabled") end) end
	elseif obj:IsA("BasePart") then
		if obj:GetAttribute("AL_OrigMaterial") == nil then
			obj:SetAttribute("AL_OrigMaterial", obj.Material.Name)
		end
		if obj:GetAttribute("AL_OrigReflectance") == nil then
			obj:SetAttribute("AL_OrigReflectance", obj.Reflectance)
		end
		if obj:GetAttribute("AL_OrigShadow") == nil then
			obj:SetAttribute("AL_OrigShadow", obj.CastShadow)
		end
		if alOptActive then
			obj.Material=Enum.Material.SmoothPlastic; obj.Reflectance=0; obj.CastShadow=false
		else
			pcall(function() obj.Material=Enum.Material[obj:GetAttribute("AL_OrigMaterial")] end)
			pcall(function() obj.Reflectance=obj:GetAttribute("AL_OrigReflectance") end)
			pcall(function() obj.CastShadow=obj:GetAttribute("AL_OrigShadow") end)
		end
	end
end

